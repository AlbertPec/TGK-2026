[node name="TechnicalNote3" parent="." index="6" unique_id=1096525025 instance=ExtResource("5_62ym3")]
position = Vector2(976, 176)
note_text = "Notatka:
\"WEWNĘTRZNE MEMO // DZIAŁ TECHNICZNY
Adresat: inż. Birch

Nie dotykaj sterowania, dopóki drzwi nie przejdą diagnostyki. Bez awaryjnego zasilania hamulce nawet się nie zablokują.

Status systemu: niestabilny
Priorytet: wysoki\""

